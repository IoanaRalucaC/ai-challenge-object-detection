# ═══════════════════════════════════
#  Python / Backend
# ═══════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
backend/.venv/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Test & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type-checker caches
.mypy_cache/
.dmypy.json
.ruff_cache/


# YOLO model weights (large binary files — use Git LFS or keep local)
backend/*.pt

# Runtime outputs
output.jpg
output.png
*.avi
*.mp4

# ═══════════════════════════════════
#  Node.js / Frontend
# ═══════════════════════════════════
node_modules/
.pnp
.pnp.js

# Build outputs
frontend/dist/
frontend/.next/
frontend/out/
frontend/build/


# Lock files (keep one — remove or adjust per your package manager)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ═══════════════════════════════════
#  Editors & OS
# ═══════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini

# VSCode — keep .vscode/ checked-in for shared settings
# .vscode/

# JetBrains
.idea/

